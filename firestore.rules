rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidComment(data, isCreate) {
      let requiredFields = ['text', 'user', 'uid', 'createdAt', 'likes', 'likedBy'];
      let hasRequired = data.keys().hasAll(requiredFields);
      
      let count = data.keys().size();
      let hasCorrectCount = count >= 6 && count <= 11; // Increased to 11 for safety
      
      let baseValid = hasRequired && hasCorrectCount &&
             data.text is string && data.text.size() <= 3000 &&
             data.user is string && data.user.size() <= 200 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.get('likes', 0) is number &&
             data.get('likedBy', []) is list;

      // Validate optional fields if present
      let photoValid = data.get('photo', '') is string && data.get('photo', '').size() <= 1000;
      let gifValid = data.get('gifUrl', '') is string && data.get('gifUrl', '').size() <= 1000;
      let replyValid = data.get('replyToId', '') is string && data.get('replyToId', '').size() <= 128;

      let timestampValid = isCreate ? (data.createdAt == request.time) : true; 
      
      return baseValid && photoValid && gifValid && replyValid && timestampValid;
    }

    match /comments/{commentId} {
      allow read: if true;
      
      allow create: if isValidComment(request.resource.data, true) && 
                      request.resource.data.get('likes', 0) == 0 && 
                      request.resource.data.get('likedBy', []).size() == 0;
      
      allow update: if (
        // Action: Toggle Like (User adds/removes their own UID and increments/decrements count)
        (isValidComment(request.resource.data, false) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy']) &&
         math.abs(request.resource.data.get('likes', 0) - resource.data.get('likes', 0)) <= 1)
      );
      
      allow delete: if false;
    }
    
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
