rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return (isSignedIn() && request.auth.uid == userId) || 
             (!isSignedIn() && userId is string && userId.startsWith("anon_"));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Comments
    function isValidComment(data) {
      let requiredFields = ['text', 'user', 'uid', 'createdAt'];
      let hasRequired = data.keys().hasAll(requiredFields);
      
      return hasRequired &&
             data.text is string && data.text.size() >= 1 && data.text.size() <= 2000 &&
             data.user is string && data.user.size() >= 1 && data.user.size() <= 200 &&
             (data.uid is string) &&
             (
               (request.auth == null && (data.uid == "anonymous" || data.uid.startsWith("anon_"))) ||
               (request.auth != null && data.uid == request.auth.uid)
             ) &&
             (data.likesCount == null || data.likesCount is number) &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Collection: comments
    // ===============================================================
    
    match /comments/{commentId} {
      allow read: if true;
      
      allow create: if isValidComment(incoming());
      
      allow update: if (
        // Action: Like/Unlike (Atomic Increment/Decrement)
        // Allow anyone to update likesCount if nothing else changes
        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
        (incoming().likesCount == existing().likesCount + 1 || incoming().likesCount == existing().likesCount - 1)
      );
      
      // Sub-collection: likes
      match /likes/{userId} {
        allow read: if true;
        allow create: if isUser(userId) && 
                      incoming().uid == userId && 
                      incoming().createdAt == request.time;
        allow delete: if isUser(userId);
      }
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
